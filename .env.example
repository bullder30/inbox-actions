# -----------------------------------------------------------------------------
# App - Don't add "/" in the end of the url (same in production)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Authentication (NextAuth.js)
# -----------------------------------------------------------------------------
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000  # Required in some deployment environments

# Google OAuth (optional - set both to enable Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=false  # Set to "true" to show Google button

# Microsoft OAuth (optional - set all to enable Microsoft login)
MICROSOFT_CLIENT_ID=                        # Application (client) ID (GUID format)
MICROSOFT_CLIENT_SECRET=                    # Client secret value
MICROSOFT_TENANT_ID=                        # Directory (tenant) ID - use "common" for multi-tenant
NEXT_PUBLIC_AUTH_MICROSOFT_ENABLED=false    # Set to "true" to show Microsoft button

# -----------------------------------------------------------------------------
# Database (PostgreSQL - Neon DB)
# -----------------------------------------------------------------------------
DATABASE_URL='postgres://[user]:[password]@[neon_hostname]/[dbname]?sslmode=require'

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM="SaaS Starter App <onboarding@resend.dev>"

# -----------------------------------------------------------------------------
# Subscriptions (Stripe)
# -----------------------------------------------------------------------------
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

NEXT_PUBLIC_STRIPE_PRO_MONTHLY_PLAN_ID=
NEXT_PUBLIC_STRIPE_PRO_YEARLY_PLAN_ID=

NEXT_PUBLIC_STRIPE_BUSINESS_MONTHLY_PLAN_ID=
NEXT_PUBLIC_STRIPE_BUSINESS_YEARLY_PLAN_ID=

# -----------------------------------------------------------------------------
# IMAP (optional - required if users connect via IMAP)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -----------------------------------------------------------------------------
IMAP_MASTER_KEY=  # 64-character hex string for AES-256-CBC encryption of IMAP passwords

# -----------------------------------------------------------------------------
# Cron Jobs
# -----------------------------------------------------------------------------
CRON_SECRET=
CRON_PROVIDER=node  # "node" (default) or "vercel"

# -----------------------------------------------------------------------------
# Feature Flags (Optional)
# -----------------------------------------------------------------------------
FEATURE_EMAIL_COUNT=false       # Enable email count job and dashboard KPI (default: false)

# -----------------------------------------------------------------------------
# Cloudflare Turnstile (Optional - CAPTCHA on register page)
# Get keys at: https://dash.cloudflare.com/ → Turnstile
# -----------------------------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=   # Shown in the browser (public)
TURNSTILE_SECRET_KEY=             # Used server-side to verify the token (keep secret)

# -----------------------------------------------------------------------------
# Support (Optional)
# -----------------------------------------------------------------------------
EMAIL_SUPPORT=